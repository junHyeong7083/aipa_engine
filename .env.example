# AIPA Engine Configuration
# Copy this file to .env and fill in your values

# Application Settings
DEBUG=false
APP_NAME=AIPA Engine
PORT=8080

# --- PostgreSQL (Firestore 대체) ---
# docker-compose 사용 시 DB_HOST 는 compose 가 'db' 로 주입하므로 비워둬도 됨.
# 로컬에서 직접 실행 시 본인 PG 정보로 채움.
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=aipa_db
DB_USER=aipa
DB_PASSWORD=

# --- 보호 라우트용 공유 Bearer 토큰 ---
# 비어 있으면 쓰기 라우트(PUT/DELETE/POST history)가 503.
# 클라이언트(flutter_app)는 같은 값을 'Authorization: Bearer <값>' 으로 전송.
# 생성 예: openssl rand -hex 32
API_BEARER_TOKEN=

# KOSIS API (Korean Statistical Information Service)
# Get your API key from: https://kosis.kr/openapi/
KOSIS_API_KEY=your_kosis_api_key_here

# Anthropic API (Claude)
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# 네이버 데이터랩 API
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# CORS (comma-separated origins, empty = allow all)
# nip.io HTTPS 예: https://34-64-36-56.nip.io
# ALLOWED_ORIGINS=http://localhost:3000,https://34-64-36-56.nip.io

# Simulation Settings
DEFAULT_PANEL_COUNT=10
MAX_PANEL_COUNT=200
